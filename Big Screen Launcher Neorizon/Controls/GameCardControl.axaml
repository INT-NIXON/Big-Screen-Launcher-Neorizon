<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Big_Screen_Launcher_Neorizon.Controls.GameCardControl">
  <UserControl.Transitions>
    <Transitions>
      <DoubleTransition Property="Opacity"
                        Duration="0:0:0.4"
                        Easing="CubicEaseOut"/>
      <ThicknessTransition Property="Margin"
                           Duration="0:0:0.35"
                           Easing="CubicEaseOut"/>
    </Transitions>
  </UserControl.Transitions>

  <Grid>
    <!-- Tile content (always visible) -->
    <Border x:Name="TileBorder"
            CornerRadius="16"
            Background="#141B2B"
            BorderBrush="#2A3A5C"
            BorderThickness="1"
            ClipToBounds="True">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity"
                            Duration="0:0:0.2"/>
        </Transitions>
      </Border.Transitions>

      <Grid RowDefinitions="*,Auto,Auto">
        <Image x:Name="CoverImage"
               Stretch="UniformToFill"
               StretchDirection="DownOnly" />

        <Border Grid.Row="0"
                Background="#A008111F" />

        <Border Grid.Row="1"
                Background="#A008111F"
                Padding="16,8">
          <TextBlock x:Name="GameName"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="#E9F1FF"
                     TextTrimming="CharacterEllipsis" />
        </Border>

        <Border Grid.Row="2"
                Background="#141B2B"
                Padding="16,8">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock x:Name="PlatformText"
                       FontSize="12"
                       Foreground="#8899BB"
                       VerticalAlignment="Center" />
            <Border x:Name="PlatformBadge"
                    Grid.Column="1"
                    CornerRadius="12"
                    Width="20"
                    Height="20"
                    VerticalAlignment="Center" />
          </Grid>
        </Border>
      </Grid>
    </Border>

    <!-- Selection frame overlay (only when selected) -->
    <Border x:Name="SelectionFrame"
            CornerRadius="19"
            Background="Transparent"
            BorderBrush="#5A7CF7"
            BorderThickness="3"
            BoxShadow="0 0 30 0 #5A7CF7"
            IsHitTestVisible="False"
            Opacity="0">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity"
                            Duration="0:0:0.25"
                            Easing="CubicEaseOut"/>
        </Transitions>
      </Border.Transitions>
    </Border>
  </Grid>
</UserControl>
