<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Big_Screen_Launcher_Neorizon.ViewModels"
             x:Class="Big_Screen_Launcher_Neorizon.Views.LibraryShellView"
             x:DataType="vm:LibraryShellViewModel"
             mc:Ignorable="d">
  <Design.DataContext>
    <vm:LibraryShellViewModel x:FactoryMethod="CreateDesignViewModel" />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto" Margin="36">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,18">
      <TextBlock Text="{Binding HomeHeader}"
                 FontSize="26"
                 FontWeight="Bold"
                 VerticalAlignment="Center" />

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="14"
                  VerticalAlignment="Center">
        <Border Background="#162133" CornerRadius="14" Padding="14,8">
          <TextBlock Text="{Binding BatteryStatus}" FontSize="16" Foreground="#E9F1FF" />
        </Border>
        <Border Background="#162133" CornerRadius="14" Padding="14,8">
          <TextBlock Text="{Binding CurrentTime}" FontSize="16" Foreground="#E9F1FF" />
        </Border>
        <Border Background="#22314D" CornerRadius="14" Padding="16,8">
          <TextBlock Text="{Binding SettingsLabel}" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" />
        </Border>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" Background="#0D1524" CornerRadius="28" />

    <StackPanel Grid.Row="2" Spacing="14" Margin="0,18,0,0" MaxHeight="240">
      <TextBlock Text="{Binding GameRailTitle}" FontSize="22" FontWeight="Bold" Margin="4,0,0,0" />

      <ListBox x:Name="GameRailList"
               ItemsSource="{Binding Games}"
               ScrollViewer.HorizontalScrollBarVisibility="Hidden"
               ScrollViewer.VerticalScrollBarVisibility="Disabled"
               Background="Transparent"
               BorderThickness="0"
               Focusable="False">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:GameTileViewModel">
            <Border Width="280"
                    Height="180"
                    CornerRadius="22"
                    Padding="0"
                    Margin="0,0,9,0"
                    Background="{Binding IsSelected, Converter={StaticResource TileBackgroundConverter}}"
                    BorderBrush="{Binding AccentHex}"
                    BorderThickness="{Binding IsSelected, Converter={StaticResource TileBorderThicknessConverter}}"
                    ClipToBounds="True">
              <Grid RowDefinitions="*,Auto,Auto">
                <Border Background="{Binding AccentHex}" Opacity="0.35" CornerRadius="22" />
                <Image Source="{Binding CoverImagePath, Converter={StaticResource StringToImageConverter}}"
                       Stretch="UniformToFill"
                       StretchDirection="DownOnly" />
                <Border Background="#A008111F" />
                <TextBlock Grid.Row="1" Text="{Binding PlatformLabel}" FontSize="14" Foreground="#BCCFF0" Margin="20,0,0,8" />
                <TextBlock Grid.Row="2" Text="{Binding Title}" FontSize="26" FontWeight="Bold" TextWrapping="Wrap" Foreground="{Binding IsSelected, Converter={StaticResource TileTextBrushConverter}}" Margin="20,0,0,16" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>
  </Grid>
</UserControl>
