<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="Big_Screen_Launcher_Neorizon.MainWindow"
        Title="Big Screen Launcher"
        WindowState="Maximized"
        Background="#0A0E17">
  <Grid>
    <!-- Main content -->
    <Border x:Name="MainContent" IsVisible="False">
      <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">
        <!-- Top bar -->
        <Border Grid.Row="0"
                VerticalAlignment="Top"
                Background="#40000000"
                Padding="24,16">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="我的游戏"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#E9F1FF"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="GameCountText"
                       Grid.Column="1"
                       FontSize="16"
                       Foreground="#8899BB"
                       VerticalAlignment="Center" />
          </Grid>
        </Border>

        <!-- Logo area (left-aligned with game list) -->
        <Border Grid.Row="2"
                Height="220"
                Margin="48,8,0,0"
                Background="Transparent"
                ClipToBounds="True">
          <Grid>
            <Image x:Name="HeroImage1"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center">
              <Image.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity"
                                    Duration="0:0:0.5"
                                    Easing="CubicEaseOut"/>
                </Transitions>
              </Image.Transitions>
            </Image>
            <Image x:Name="HeroImage2"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Opacity="0">
              <Image.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity"
                                    Duration="0:0:0.5"
                                    Easing="CubicEaseOut"/>
                </Transitions>
              </Image.Transitions>
            </Image>
          </Grid>
        </Border>

        <!-- Game rail -->
        <ScrollViewer x:Name="GameScroller"
                      Grid.Row="3"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Background="Transparent">
          <StackPanel x:Name="GamePanel"
                      Orientation="Horizontal"
                      Margin="48,8,0,16"
                      Spacing="20" />
        </ScrollViewer>

        <!-- Input hints (own row, below game rail) -->
        <Border Grid.Row="4"
                HorizontalAlignment="Right"
                Margin="0,8,36,8"
                Padding="18,12"
                CornerRadius="14"
                Background="#CC1A2740">
          <StackPanel Orientation="Horizontal" Spacing="24">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Image x:Name="HintDpad" Width="24" Height="24" Stretch="Uniform" />
              <TextBlock Text="导航" FontSize="14" Foreground="#E9F1FF" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Image x:Name="HintA" Width="24" Height="24" Stretch="Uniform" />
              <TextBlock Text="启动" FontSize="14" Foreground="#E9F1FF" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Image x:Name="HintB" Width="24" Height="24" Stretch="Uniform" />
              <TextBlock Text="返回" FontSize="14" Foreground="#E9F1FF" VerticalAlignment="Center" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
